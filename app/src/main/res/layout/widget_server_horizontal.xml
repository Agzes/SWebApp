<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_background"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp"
    android:gravity="center_vertical"
>

    <LinearLayout
        android:id="@+id/widgetBtnToggle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/widget_btn_bg_start"
    >

        <ImageView
            android:id="@+id/widgetToggleIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_play"
        />

        <TextView
            android:id="@+id/widgetToggleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start"
            android:textSize="14sp"
            android:textColor="#003510"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginStart="8dp"
        />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
    >

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
        >
            <TextView
                android:id="@+id/widgetStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Offline"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
            />
            <ImageView
                android:id="@+id/widgetStatusIcon"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_status_dot_offline"
            />
        </LinearLayout>

        <TextView
            android:id="@+id/widgetUrlText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Server is stopped"
            android:textColor="#A0A0A0"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1"
        />
    </LinearLayout>

    <FrameLayout
        android:layout_width="12dp"
        android:layout_height="match_parent"
    />

    <ImageButton
        android:id="@+id/widgetBtnApp"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_apps"
        android:background="@drawable/widget_btn_bg_secondary"
        android:contentDescription="Open App"
    />

    <FrameLayout
        android:layout_width="12dp"
        android:layout_height="match_parent"
        android:id="@+id/widgetSpaceBrowser"
    />

    <ImageButton
        android:id="@+id/widgetBtnBrowser"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_open_in_new"
        android:background="@drawable/widget_btn_bg_secondary"
        android:visibility="gone"
        android:contentDescription="Open Browser"
    />

</LinearLayout>
