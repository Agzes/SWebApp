<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="10dp"
    android:gravity="center"
>

    <ImageView
        android:id="@+id/widgetStatusIcon"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:src="@drawable/ic_status_dot_offline"
        android:layout_marginBottom="8dp"
    />

    <LinearLayout
        android:id="@+id/widgetBtnToggle"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:background="@drawable/widget_btn_bg_start"
    >

        <ImageView
            android:id="@+id/widgetToggleIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_play"
            android:contentDescription="Toggle Server"
        />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="8dp"
    />

    <ImageButton
        android:id="@+id/widgetBtnApp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:src="@drawable/ic_apps"
        android:scaleType="centerInside"
        android:background="@drawable/widget_btn_bg_secondary"
        android:contentDescription="Open App"
    />

    <TextView
        android:id="@+id/widgetStatusText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
    />
    <TextView
        android:id="@+id/widgetUrlText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
    />
    <TextView
        android:id="@+id/widgetToggleText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
    />
    <FrameLayout
        android:id="@+id/widgetSpaceBrowser"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
    />
    <ImageButton
        android:id="@+id/widgetBtnBrowser"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/ic_open_in_new"
        android:visibility="gone"
        android:contentDescription="Open Browser"
    />

</LinearLayout>
